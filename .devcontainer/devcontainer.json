{
  "name": "Nukhba Flutter Dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "onCreateCommand": "git clone https://github.com/flutter/flutter.git -b stable --depth 1 $HOME/flutter && echo 'export PATH=\"$PATH:$HOME/flutter/bin\"' >> $HOME/.bashrc",
  "postCreateCommand": "export PATH=\"$PATH:$HOME/flutter/bin\" && flutter --version && flutter config --no-analytics",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/flutter/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  },
  "hostRequirements": {
    "cpus": 2,
    "memory": "8gb"
  }
}
