# Nukhba backend configuration. Copy to .env and fill in.
# SECURITY: the service-role key bypasses RLS. Never commit .env. (Security ADR s7)

# Postgres (Supabase managed). Use the service-role/privileged connection ON THE SERVER ONLY.
NUKHBA_PG_HOST=localhost
NUKHBA_PG_PORT=5432
NUKHBA_PG_DATABASE=postgres
NUKHBA_PG_USERNAME=postgres
NUKHBA_PG_PASSWORD=
NUKHBA_PG_SSL=require

# Supabase Auth (JWT verification). The backend verifies Supabase-issued JWTs
# locally (Security ADR s2): primary ES256 via the project JWKS endpoint, with
# an HS256 shared-secret fallback for legacy projects.
#
# Required: the project ref (the `<ref>` in https://<ref>.supabase.co). The
# expected issuer and JWKS URI are derived from it so they cannot drift.
NUKHBA_SUPABASE_PROJECT_REF=
# Optional: expected audience claim (defaults to `authenticated`).
NUKHBA_SUPABASE_JWT_AUD=authenticated
# Optional: legacy shared HS256 secret. Set ONLY for legacy (pre-2025-10)
# projects still signing with the project JWT secret. Absent on modern
# ES256-only projects. SECURITY: never commit a real value.
NUKHBA_SUPABASE_JWT_SECRET=

# Server
NUKHBA_ENV=development
NUKHBA_PORT=8080
